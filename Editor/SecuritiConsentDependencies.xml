    <androidPackage spec="ai.securiti.cmpsdkcore:consent-sdk:1.144.0">
      <repositories>
        <repository>https://cdn-qa.securiti.xyz/consent/maven</repository>
      </repositories>
    </androidPackage>

    <!-- Kotlin Coroutines -->
    <androidPackage spec="org.jetbrains.kotlinx:kotlinx-coroutines-core:1.7.3" />
    <androidPackage spec="org.jetbrains.kotlinx:kotlinx-coroutines-android:1.7.3" />

    <!-- AndroidX Dependencies -->
